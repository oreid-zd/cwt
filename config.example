# cwt config — copy to ~/.config/cwt/config (or set CWT_CONFIG to point elsewhere).
# Anything you set in your shell env overrides these values.

# Override the default branch. Leave unset to auto-detect from origin/HEAD
# (falls back to the current branch, then "main").
# CWT_DEFAULT_BRANCH=master

# Extra base branches to fetch and check merge status against, space-separated.
# CWT_EXTRA_BASES="mvp develop"

# Relative path (from the repo root) of the "sandcastle" worktree dir. The list
# label is derived from the leading segment (".sandcastle/worktrees" -> "sandcastle").
# CWT_SANDCASTLE_DIR=".sandcastle/worktrees"
